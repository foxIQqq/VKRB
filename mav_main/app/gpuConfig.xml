    Настройки отображения OSD

    visibility:     (0/1)  Отображать элемент на экране или нет
    positionX:      (0-29) Координата Х элемента
    positionY:      (0-15) Координата Y элемента

    Экран разбит 30х16, начиная с левого верхнего угла
-->

<Configuration>
    <Altitude
        visibility="0"
        positionX="0"
