        visibility="1"
        positionX="17"
        positionY="10"
    />
    <Control
        visibility="1"
        positionX="14"
        positionY="10"
    />
    <Pitch
        visibility="0"
        positionX="0"
        positionY="13"
    />
    <Roll
        visibility="0"
        positionX="0"
        positionY="14"
    />
    <Yaw
        visibility="0"
        positionX="0"
        positionY="15"
    />
    <Voltage
        visibility="0"
        positionX="22"
        positionY="15"
    />
